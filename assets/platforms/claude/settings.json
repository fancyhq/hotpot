{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hotpot hook claude pre-tool-use",
            "timeout": 5,
            "statusMessage": "Preparing Hotpot shell context"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "hotpot-execution|hotpot-review",
        "hooks": [
          {
            "type": "command",
            "command": "hotpot hook claude subagent-start",
            "timeout": 5,
            "statusMessage": "Preparing Hotpot review memory"
          }
        ]
      }
    ]
  }
}
