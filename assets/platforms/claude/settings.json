{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hotpot hook claude pre-tool-use",
            "timeout": 5,
            "statusMessage": "Injecting lightweight Hotpot context"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "hotpot-execution|hotpot-review",
        "hooks": [
          {
            "type": "command",
            "command": "hotpot hook claude subagent-start",
            "timeout": 5,
            "statusMessage": "Preparing Hotpot review memory"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "hotpot hook claude session-end",
            "timeout": 5,
            "statusMessage": "Releasing Hotpot VuePress server"
          }
        ]
      }
    ]
  }
}
